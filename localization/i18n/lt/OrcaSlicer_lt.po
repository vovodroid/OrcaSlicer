msgstr "Bendras svoris"

msgid "Total weight of the print. Calculated from filament_density value in Filament Settings."
msgstr "Bendras spaudinio svoris. Apskaičiuojama pagal „filament_density“ reikšmę Gijos nustatymuose."

msgid "Total layer count"
msgstr "Bendras sluoksnių skaičius"

