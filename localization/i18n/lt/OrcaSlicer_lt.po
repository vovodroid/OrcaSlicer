#~ msgstr "Sąsajai naudoti kontūro raštą"

#~ msgid "Cover the top contact layer of the supports with loops. Disabled by default."
#~ msgstr "Viršutinį kontaktinį atramų sluoksnį užpildyti uždarais kontūrais (loops). Gamykliškai išjungta."

