msgstr "Valymo bokštelio tūris"

msgid "Total filament volume extruded on the wipe tower."
msgstr "Bendras gijos tūris, išspaustas (extruded) ant valymo bokštelio."

msgid "Used filament"
msgstr "Naudota gija"

