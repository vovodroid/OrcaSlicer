msgstr "Įkelti gijos nustatymus iš nurodyto failų sąrašo."

msgid "Skip Objects"
msgstr "Praleisti objektus"

msgid "Skip some objects in this print."
msgstr "Praleisti kai kuriuos šio spausdinimo objektus."

msgid "Clone Objects"
msgstr "Klonuoti objektus"

