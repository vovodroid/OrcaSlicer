msgstr "Išdėstymo parinktys"

msgid "Arrange options: 0-disable, 1-enable, others-auto"
msgstr "Išdėstymo parinktys: 0 – išjungti, 1 – įjungti, kitos – automatiškai"

msgid "Repetition count"
